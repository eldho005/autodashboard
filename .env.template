# ==========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy this file to .env.local for local development
# Set these values in Railway Dashboard → Variables for production
# ==========================================

# ===== SUPABASE DATABASE =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===== META/FACEBOOK API =====
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_PAGE_ID=your_page_id
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_LEAD_FORM_ID=your_lead_form_id
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
FB_PIXEL_ID=your_pixel_id
FB_PIXEL_TOKEN=your_pixel_token

# ===== JWT AUTHENTICATION =====
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_secure_random_key_here
ADMIN_EMAIL=policy@meta.com
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'policy@123', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# ===== CORS & SECURITY =====
# Local: http://localhost:5000,http://127.0.0.1:5000
# Production: https://your-app.up.railway.app
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
# Local: false, Production: true
COOKIE_SECURE=false
# Max file upload size in MB
MAX_UPLOAD_MB=32

# ===== SIGNWELL E-SIGNATURE =====
SIGNWELL_API_KEY=your_api_key_here
SIGNWELL_WEBHOOK_SECRET=your_webhook_secret_here

# ===== MS OFFICE EMAIL =====
MS_OFFICE_EMAIL=your_email@domain.com
MS_OFFICE_EMAIL_PASSWORD=your_password
MS_OFFICE_SMTP_SERVER=smtp.office365.com
MS_OFFICE_SMTP_PORT=587
DELIVERY_EMAIL=your_delivery_email@domain.com

# ===== AZURE/MS GRAPH API =====
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
MS_GRAPH_REFRESH_TOKEN=your_refresh_token

# ===== GOOGLE CLOUD / VERTEX AI =====
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash
# Optional: Path to service account JSON (not recommended for Railway)
# GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account-key.json

# ===== ZOHO SIGN (LEGACY) =====
ZOHO_SIGN_CLIENT_ID=your_client_id
ZOHO_SIGN_CLIENT_SECRET=your_client_secret
ZOHO_SIGN_REFRESH_TOKEN=your_refresh_token
ZOHO_SIGN_API_BASE=https://sign.zohocloud.ca/api/v1

# ===== STREAMLIT SIDECAR SERVICES (OPTIONAL) =====
# Local development defaults
STREAMLIT_AUTO_URL=http://localhost:8502
STREAMLIT_TENANT_URL=http://localhost:8503
# Production: Deploy Streamlit apps separately and update URLs
# STREAMLIT_AUTO_URL=https://auto-coverpage.up.railway.app
# STREAMLIT_TENANT_URL=https://tenant-coverpage.up.railway.app

# ===== FLASK DEVELOPMENT =====
FLASK_PORT=5000
FLASK_ENV=development
